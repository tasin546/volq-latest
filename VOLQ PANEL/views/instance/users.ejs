<%- include('../components/template') %>
<main class="p-12 lg:p-16 space-y-12" id="content">
    <!-- Header Protocol -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 border-b border-white/5 pb-10">
        <div class="space-y-2">
            <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Identity Management</div>
            <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none">Access Protocol</h2>
            <p class="text-zinc-500 text-sm font-medium">Delegate administrative privileges and coordinate multi-operator resource access.</p>
        </div>

        <button id="openAddModal" class="px-8 py-3.5 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-blue-500/20 active:scale-95 flex items-center gap-3">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
            Authorize Operator
        </button>
    </div>

    <%- include('../components/instance') %>

    <!-- Authorization Ledger -->
    <div class="liquid-glass rounded-[3rem] border border-white/5 shadow-3xl overflow-hidden relative">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/[0.02] border-b border-white/5">
                        <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Operator Identity</th>
                        <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-right">Operations</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.02]">
                    <% if (users.length === 0) { %>
                        <tr>
                            <td colspan="2" class="px-8 py-12 text-center text-zinc-600 text-[10px] font-bold uppercase tracking-[0.2em]">No auxiliary operators authorized for this unit.</td>
                        </tr>
                    <% } %>
                    <% users.forEach(function(user) { %>
                        <tr class="hover:bg-white/[0.01] transition-colors group cursor-pointer">
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    </div>
                                    <div class="space-y-1">
                                        <span class="text-xs font-bold text-white uppercase tracking-tight block"><%= user.username %></span>
                                        <span class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest"><%= user.userId %></span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-6 text-right">
                                <button onclick="location.href='/instance/<%= req.params.id %>/users/remove/<%= user.username %>'" class="px-6 py-2 bg-rose-600/10 hover:bg-rose-500 text-rose-500 hover:text-white text-[9px] font-black uppercase tracking-widest rounded-xl transition active:scale-95">Revoke Access</button>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<!-- Invitation Modal -->
<div id="modalOverlay" class="fixed inset-0 bg-[#0a0a0c]/80 backdrop-blur-sm z-[60] hidden flex items-center justify-center p-6">
    <div class="liquid-glass border border-white/5 p-12 rounded-[3.5rem] w-full max-w-md shadow-4xl space-y-10">
        <div class="space-y-4 text-center">
            <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center font-black text-white text-xl mx-auto mb-6 shadow-2xl shadow-blue-500/20">U</div>
            <div class="space-y-2">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mx-auto tracking-tighter uppercase">Authority Delegate</div>
                <h3 class="text-3xl font-black text-white tracking-tight">Authorize Operator</h3>
                <p class="text-zinc-500 text-xs font-medium">Coordinate a new administrative entity for this unit.</p>
            </div>
        </div>

        <form action="/instance/<%= req.params.id %>/users/add" method="POST" class="space-y-8">
            <div class="space-y-2">
                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Operator Alias</label>
                <input type="text" name="username" placeholder="nexus_operator_01" required class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm outline-none focus:ring-1 focus:ring-blue-500/30 transition-all placeholder:text-zinc-800">
            </div>

            <div class="flex gap-4 pt-4">
                <button type="button" id="closeModal" class="flex-1 py-4 bg-white/5 hover:bg-white/10 text-white text-[10px] font-bold uppercase tracking-widest rounded-2xl transition">Decline</button>
                <button type="submit" class="flex-1 py-4 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl transition shadow-3xl shadow-blue-500/20">Commit Access</button>
            </div>
        </form>
    </div>
</div>

<script>
    const over = document.getElementById('modalOverlay');
    document.getElementById('openAddModal').onclick = () => over.classList.remove('hidden');
    document.getElementById('closeModal').onclick = () => over.classList.add('hidden');
    over.onclick = (e) => { if(e.target === over) over.classList.add('hidden') };
</script>
<%- include('../components/footer') %>