<%- include('../components/template') %>
<!-- High-Precision Telemetry & Command Infrastructure -->
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xterm@4.19.0/lib/xterm.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@4.19.0/css/xterm.min.css" />
<script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.5.0/lib/xterm-addon-fit.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    .xterm-viewport { overflow-y: auto !important; background: #0d1117 !important; }
    .xterm-screen { background: #0d1117 !important; }
    .xterm-rows { color: #c9d1d9 !important; font-family: 'JetBrains Mono', 'Fira Code', monospace !important; }
    #terminal { background: #0d1117; }
    .chart-canvas { pointer-events: none; }
</style>

<main class="p-4 sm:p-8 lg:p-16 space-y-8 lg:space-y-12" id="content">
    <!-- Header Protocol -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 border-b border-white/5 pb-10">
        <div class="space-y-2">
            <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Command Interface</div>
            <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none"><%= instance.Name %></h2>
            <div class="flex items-center gap-4 text-zinc-500 text-sm font-medium">
                <span class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-zinc-800" id="status-blob"></div>
                    <span id="status-text">INITIALIZING...</span>
                </span>
                <span class="w-px h-3 bg-white/10"></span>
                <span class="font-mono text-[11px] uppercase tracking-widest text-zinc-600"><%= req.params.id %></span>
            </div>
        </div>

        <div class="flex flex-wrap gap-4">
            <button id="startButton" class="px-8 py-3.5 bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-emerald-500/20 active:scale-95 flex items-center gap-3 group">
                <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                Launch
            </button>
            <button id="restartButton" class="px-8 py-3.5 bg-white/[0.03] border border-white/5 hover:border-white/10 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition active:scale-95 flex items-center gap-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 4v5h0.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                Reboot
            </button>
            <button id="stopButton" class="px-8 py-3.5 bg-rose-600/10 border border-rose-500/20 text-rose-500 hover:bg-rose-500 hover:text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition active:scale-95 flex items-center gap-3">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h12v12H6z"/></svg>
                Terminate
            </button>
        </div>
    </div>

    <%- include('../components/instance') %>

    <!-- Telemetry Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="liquid-glass p-6 sm:p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -right-16 -top-16 w-48 h-48 bg-blue-600/5 rounded-full blur-[60px]"></div>
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Primary Point</span>
            <div class="flex items-center gap-2">
                <span class="text-sm sm:text-xl font-black text-white tracking-wider min-w-0 truncate"><%= instance.Node.address %>:<span class="text-blue-500"><%= instance.Primary %></span></span>
                <button id="copyIpBtn" class="p-2 rounded-xl bg-white/5 hover:bg-white/10 text-zinc-400 hover:text-white transition flex-shrink-0" title="Copy IP">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                </button>
            </div>
        </div>
        <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -right-16 -top-16 w-48 h-48 bg-purple-600/5 rounded-full blur-[60px]"></div>
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Instance ID</span>
            <span class="text-sm font-black text-white font-mono tracking-wider truncate block"><%= req.params.id %></span>
        </div>
        <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -right-16 -top-16 w-48 h-48 bg-zinc-600/5 rounded-full blur-[60px]"></div>
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Hardware Location</span>
            <span class="text-xl font-black text-white tracking-tighter"><%= instance.Node.name %></span>
        </div>
        <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -right-16 -top-16 w-48 h-48 bg-emerald-600/5 rounded-full blur-[60px]"></div>
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Compute Limit</span>
            <span class="text-xl font-black text-white tracking-tighter"><%= instance.Memory %> MiB / <%= instance.Cpu %> Core</span>
        </div>
    </div>

    <!-- Interface Matrix -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-10" style="min-height:600px">
        <!-- Terminal Nexus -->
        <div class="lg:col-span-2 flex flex-col rounded-2xl border border-white/10 shadow-3xl overflow-hidden" style="background:#0d1117;min-height:480px">
            <!-- Terminal status bar -->
            <div class="px-4 py-2 border-b border-white/5 flex items-center justify-end" style="background:#161b22">
                <span class="text-[10px] font-mono text-zinc-500" id="term-status-label">CONNECTING...</span>
            </div>

            <!-- xterm area -->
            <div class="flex-1 overflow-hidden" id="terminal-wrapper" style="background:#0d1117;padding:8px 4px 4px 4px">
                <div id="terminal" style="height:100%"></div>
            </div>

            <!-- Input bar -->
            <div class="px-4 py-3 border-t border-white/5 flex items-center gap-3" style="background:#161b22">
                <span class="text-emerald-400 font-mono text-sm select-none">$</span>
                <input id="input" type="text" autocomplete="off" spellcheck="false" placeholder="Type a command and press Enter..."
                    class="flex-1 bg-transparent border-none outline-none text-sm font-mono text-zinc-200 placeholder:text-zinc-600">
                <button onclick="document.getElementById('input').dispatchEvent(new KeyboardEvent('keypress',{key:'Enter',bubbles:true}))" 
                    class="px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider text-zinc-500 border border-white/5 hover:border-emerald-500/40 hover:text-emerald-400 transition">
                    Send
                </button>
            </div>
        </div>

        <!-- Telemetry Streams -->
        <div class="flex flex-col gap-4">
            <div class="flex-1 liquid-glass rounded-2xl p-6 border border-white/5 relative overflow-hidden">
                <div class="flex justify-between items-center relative z-10 mb-2">
                    <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">RAM</span>
                    <span id="ramUsage" class="text-xs font-black text-blue-400 tracking-widest leading-none">0%</span>
                </div>
                <div class="relative z-10 w-full h-1 rounded-full bg-white/5 mb-1 overflow-hidden">
                    <div id="ramBar" class="h-full rounded-full bg-blue-500 transition-all duration-500" style="width:0%"></div>
                </div>
                <div class="absolute inset-0 z-0" style="opacity:0.5">
                    <canvas id="ramChart" class="chart-canvas"></canvas>
                </div>
            </div>

            <div class="flex-1 liquid-glass rounded-2xl p-6 border border-white/5 relative overflow-hidden">
                <div class="flex justify-between items-center relative z-10 mb-2">
                    <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">CPU</span>
                    <span id="cpuUsage" class="text-xs font-black text-rose-400 tracking-widest leading-none">0%</span>
                </div>
                <div class="relative z-10 w-full h-1 rounded-full bg-white/5 mb-1 overflow-hidden">
                    <div id="cpuBar" class="h-full rounded-full bg-rose-500 transition-all duration-500" style="width:0%"></div>
                </div>
                <div class="absolute inset-0 z-0" style="opacity:0.5">
                    <canvas id="cpuChart" class="chart-canvas"></canvas>
                </div>
            </div>

            <div class="flex-1 liquid-glass rounded-2xl p-6 border border-white/5 relative overflow-hidden">
                <div class="flex justify-between items-center relative z-10 mb-2">
                    <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Disk</span>
                    <span id="diskUsage" class="text-xs font-black text-emerald-400 tracking-widest leading-none">0 MiB</span>
                </div>
                <div class="relative z-10 w-full h-1 rounded-full bg-white/5 mb-1 overflow-hidden">
                    <div id="diskBar" class="h-full rounded-full bg-emerald-500 transition-all duration-500" style="width:0%"></div>
                </div>
                <div class="absolute inset-0 z-0" style="opacity:0.5">
                    <canvas id="diskChart" class="chart-canvas"></canvas>
                </div>
            </div>

            <!-- Live log count badge -->
            <div class="liquid-glass rounded-2xl p-4 border border-white/5 flex items-center justify-between">
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Log Lines</span>
                <span id="logCount" class="text-xs font-black text-zinc-300 font-mono">0</span>
            </div>
        </div>
    </div>
</main>

<script>
    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    let term, ws;
    let isStarting = false;
    let lastStartAt = 0;
    const START_GRACE_MS = 120000;

    const baseTheme = {
        background:     '#0d1117',
        foreground:     '#c9d1d9',
        cursor:         '#58a6ff',
        cursorAccent:   '#0d1117',
        selectionBackground: '#264f78',
        black:          '#0d1117',
        red:            '#ff7b72',
        green:          '#3fb950',
        yellow:         '#d29922',
        blue:           '#58a6ff',
        magenta:        '#bc8cff',
        cyan:           '#39c5cf',
        white:          '#b1bac4',
        brightBlack:    '#6e7681',
        brightRed:      '#ffa198',
        brightGreen:    '#56d364',
        brightYellow:   '#e3b341',
        brightBlue:     '#79c0ff',
        brightMagenta:  '#d2a8ff',
        brightCyan:     '#56d4dd',
        brightWhite:    '#ffffff'
    };

    let logLineCount = 0;

    function setTermStatus(connected) {
        const lbl = document.getElementById('term-status-label');
        if (!lbl) return;
        if (connected) {
            lbl.textContent = 'CONNECTED';
        } else {
            lbl.textContent = 'RECONNECTING...';
        }
    }
    
    function panelLog(message, level = 'info') {
        if (!term) return;
        const color = level === 'error' ? '\x1b[31m' : (level === 'warn' ? '\x1b[33m' : '\x1b[36m');
        const now = new Date().toLocaleTimeString([], { hour12: false });
        term.write(`\r\n${color}[${now}][panel]\x1b[0m ${message}`);
    }

    function updatePowerButtonStates(isOnline) {
        const startButton = document.getElementById('startButton');
        const stopButton = document.getElementById('stopButton');
        const restartButton = document.getElementById('restartButton');
        if (!startButton || !stopButton || !restartButton) return;
        startButton.disabled = isOnline || isStarting;
        stopButton.disabled = !isOnline;
        restartButton.disabled = !isOnline;
        startButton.classList.toggle('opacity-50', startButton.disabled);
        stopButton.classList.toggle('opacity-50', stopButton.disabled);
        restartButton.classList.toggle('opacity-50', restartButton.disabled);
    }

    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);
        ws.onopen = () => {
            setTermStatus(true);
            panelLog('Console socket connected');
        };
        ws.onmessage = (msg) => {
            term.write(msg.data);
            logLineCount += (msg.data.match(/\n/g) || []).length;
            const el = document.getElementById('logCount');
            if (el) el.textContent = logLineCount;

            const normalized = String(msg.data || '');
            if (/Done|For help, type "help"/i.test(normalized)) {
                isStarting = false;
                panelLog('Server reported running state');
            } else if (/Stopping server|Closing Server|Shutdown complete|exited with code/i.test(normalized)) {
                isStarting = false;
                panelLog('Server reported stop event', 'warn');
            }
        };
        ws.onclose = () => {
            setTermStatus(false);
            panelLog('Console socket disconnected, reconnecting...', 'warn');
            setTimeout(initWebSocket, 3000);
        };
        ws.onerror  = () => {
            setTermStatus(false);
            panelLog('Console socket error', 'error');
        };
    }

    function setupTerminal() {
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.5,
            theme: baseTheme,
            fontFamily: "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
            fontSize: 13,
            allowTransparency: false,
            scrollback: 2000,
            convertEol: true
        });
        const fitAddon = new FitAddon.FitAddon();
        term.loadAddon(fitAddon);
        term.open(document.getElementById('terminal'));
        fitAddon.fit();
        window.addEventListener('resize', () => fitAddon.fit());
    }

    function createChart(id, color) {
        return new Chart(document.getElementById(id).getContext('2d'), {
            type: 'line',
            data: {
                labels: Array(20).fill(''),
                datasets: [{
                    data: Array(20).fill(0),
                    borderColor: color,
                    borderWidth: 2,
                    pointRadius: 0,
                    fill: { target: 'origin', above: color + '10' },
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { display: false }, y: { display: false } },
                animation: false
            }
        });
    }

    const ramC = createChart('ramChart', '#3b82f6');
    const cpuC = createChart('cpuChart', '#ef4444');
    const diskC = createChart('diskChart', '#10b981');

    function updateChart(chart, val) {
        chart.data.datasets[0].data.shift();
        chart.data.datasets[0].data.push(val);
        chart.update();
    }

    function initStats() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);
        statsWs.onmessage = e => {
            try {
                const s = JSON.parse(e.data);
                if (s.cpu_stats && s.precpu_stats) {
                    const cpuDelta = s.cpu_stats.cpu_usage.total_usage - s.precpu_stats.cpu_usage.total_usage;
                    const systemDelta = s.cpu_stats.system_cpu_usage - s.precpu_stats.system_cpu_usage;
                    const cpu = (systemDelta > 0 && cpuDelta > 0) ? ((cpuDelta / systemDelta) * (s.cpu_stats.online_cpus || 1) * 100).toFixed(1) : '0.0';
                    document.getElementById('cpuUsage').textContent = cpu + '%';
                    const cpuBarEl = document.getElementById('cpuBar');
                    if (cpuBarEl) cpuBarEl.style.width = Math.min(parseFloat(cpu), 100) + '%';
                    updateChart(cpuC, parseFloat(cpu));
                }
                if (s.memory_stats && s.memory_stats.limit > 0) {
                    const ram = ((s.memory_stats.usage / s.memory_stats.limit) * 100).toFixed(1);
                    document.getElementById('ramUsage').textContent = ram + '%';
                    const ramBarEl = document.getElementById('ramBar');
                    if (ramBarEl) ramBarEl.style.width = Math.min(parseFloat(ram), 100) + '%';
                    updateChart(ramC, parseFloat(ram));
                }

                if (s.volumeSize !== undefined) {
                    const diskMiB = parseFloat(s.volumeSize) || 0;
                    const diskPct = s.diskLimit > 0 ? Math.min((diskMiB / s.diskLimit) * 100, 100).toFixed(1) : 0;
                    document.getElementById('diskUsage').textContent = diskMiB.toFixed(1) + ' MiB';
                    const diskBarEl = document.getElementById('diskBar');
                    if (diskBarEl) diskBarEl.style.width = diskPct + '%';
                    updateChart(diskC, parseFloat(diskPct));
                }

                const stateText = String(s.state || s.status || '').toUpperCase();
                const memOnline = (s.memory_stats && s.memory_stats.usage > 0);
                const now = Date.now();
                const withinGrace = isStarting && (now - lastStartAt < START_GRACE_MS);
                const status = ['RUNNING', 'ONLINE'].includes(stateText) || memOnline
                    ? 'ONLINE'
                    : (withinGrace ? 'STARTING...' : 'OFFLINE');
                document.getElementById('status-text').textContent = status;
                document.getElementById('status-blob').className = `w-2 h-2 rounded-full ${
                    status === 'ONLINE'
                        ? 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]'
                        : (status === 'STARTING...'
                            ? 'bg-amber-400 shadow-[0_0_10px_rgba(251,191,36,0.5)]'
                            : 'bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]')
                }`;
                updatePowerButtonStates(status === 'ONLINE');
            } catch(e) {}
        };
        statsWs.onclose = () => setTimeout(initStats, 3000);
    }

    document.addEventListener('DOMContentLoaded', () => {
        setupTerminal();
        initWebSocket();
        initStats();

        // Copy IP button
        function copyToClipboard(text) {
            if (navigator.clipboard && window.isSecureContext) {
                return navigator.clipboard.writeText(text);
            }
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            try { document.execCommand('copy'); } catch (e) {}
            document.body.removeChild(ta);
            return Promise.resolve();
        }

        const copyBtn = document.getElementById('copyIpBtn');
        if (copyBtn) {
            const serverIp = '<%= instance.Node.address %>:<%= instance.Primary %>';
            copyBtn.addEventListener('click', () => {
                copyToClipboard(serverIp).then(() => {
                    copyBtn.innerHTML = '<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
                    setTimeout(() => {
                        copyBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
                    }, 1500);
                });
            });
        }

        const input = document.getElementById('input');
        input.onkeypress = (e) => {
            if (e.key === 'Enter' && input.value.trim() && ws) {
                term.write('\r\n\x1b[33m~ \x1b[0m' + input.value + '\r\n');
                ws.send(JSON.stringify({ event: 'cmd', command: input.value, containerId: instanceId }));
                input.value = '';
            }
        };

        ['start', 'stop', 'restart'].forEach(action => {
            document.getElementById(`${action}Button`).onclick = () => {
                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({ event: `power:${action}`, containerId: instanceId }));
                    panelLog(`Sent ${action} command to server`);
                    if (action === 'start' || action === 'restart') {
                        isStarting = true;
                        lastStartAt = Date.now();
                    } else if (action === 'stop') {
                        isStarting = false;
                    }
                    updatePowerButtonStates(false);
                } else {
                    panelLog('Cannot send command: websocket disconnected', 'error');
                }
            };
        });
    });
</script>
<%- include('../components/footer') %>