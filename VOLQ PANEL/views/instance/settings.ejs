<%- include('../components/template') %>
<main class="p-12 lg:p-16 space-y-12" id="content">
    <!-- Header Protocol -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 border-b border-white/5 pb-10">
        <div class="space-y-2">
            <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">System Configuration</div>
            <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none">Instance Blueprint</h2>
            <p class="text-zinc-500 text-sm font-medium">Reconfigure core identity and structural parameters for this infrastructure unit.</p>
        </div>
    </div>

    <%- include('../components/instance') %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Identity Module -->
        <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-blue-500/10 border border-blue-500/20 rounded-xl flex items-center justify-center text-blue-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight leading-none">Identity Core</h3>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest mt-1">Classification & Branding</p>
                </div>
            </div>

            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1 text-center">Unit Alias</label>
                    <input id="name" type="text" value="<%= instance.Name %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                </div>
                <button id="save" class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-blue-500/20 active:scale-95">Commit Identity Changes</button>
            </div>
        </div>

        <!-- Maintenance Module -->
        <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
            <div class="flex items-center gap-4 text-rose-500">
                <div class="w-10 h-10 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight leading-none">Stability Protocol</h3>
                    <p class="text-rose-500 text-[10px] font-bold uppercase tracking-widest mt-1">Destructive Operations</p>
                </div>
            </div>

            <div class="p-6 bg-rose-500/5 border border-rose-500/10 rounded-2xl space-y-4">
                <p class="text-zinc-400 text-xs font-medium leading-relaxed">System-wide reinstallation will purge all local assets and re-deploy the environment blueprint. This action is irreversible.</p>
                <button onclick="reinstall()" class="w-full py-4 bg-rose-600/10 hover:bg-rose-500 text-rose-500 hover:text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl border border-rose-500/20 transition active:scale-95">Purge & Reinstall</button>
            </div>
        </div>
    </div>
</main>

<!-- Loading Overlay -->
<div id="loadingPopup" class="fixed inset-0 bg-[#0a0a0c]/80 backdrop-blur-md z-[60] hidden flex items-center justify-center p-6">
    <div class="liquid-glass border border-white/5 p-12 rounded-[3.5rem] w-full max-w-md shadow-4xl space-y-10">
        <div class="space-y-4 text-center">
            <svg class="w-12 h-12 text-blue-500 animate-spin mx-auto mb-6" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <div class="space-y-2">
                <h3 class="text-2xl font-black text-white tracking-tight uppercase">Executing Reinstall</h3>
                <p id="loadingMessage" class="text-zinc-500 text-[10px] font-bold uppercase tracking-[0.2em]">Synchronizing Registry...</p>
            </div>
        </div>
        <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden border border-white/5">
            <div id="loadingBar" class="h-full w-0 bg-blue-600 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
        </div>
    </div>
</div>

<script>
    document.getElementById('save').onclick = () => {
        const n = document.getElementById('name').value.trim();
        window.location.href = `/instance/<%= req.params.id %>/change/name/${encodeURIComponent(n)}`;
    }

    async function reinstall() {
        if(!confirm("Are you sure you want to purge and reinstall this unit?")) return;
        
        const popup = document.getElementById('loadingPopup');
        const bar = document.getElementById('loadingBar');
        const msg = document.getElementById('loadingMessage');
        
        popup.classList.remove('hidden');
        popup.classList.add('flex');
        
        try {
            const res = await fetch(`/instance/reinstall/<%= req.params.id %>`, { method: 'POST' });
            let prog = 0;
            const iv = setInterval(() => {
                if(prog < 95) {
                    prog += Math.random() * 15;
                    bar.style.width = Math.min(prog, 95) + '%';
                }
            }, 300);

            if(res.ok) {
                setTimeout(() => {
                    clearInterval(iv);
                    bar.style.width = '100%';
                    msg.textContent = 'PROTOCOL COMPLETE';
                    setTimeout(() => window.location.reload(), 1000);
                }, 1500);
            }
        } catch(e) { popup.classList.add('hidden'); }
    }
</script>
<%- include('../components/footer') %>