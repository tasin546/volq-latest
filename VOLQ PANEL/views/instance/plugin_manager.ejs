<%- include('../components/template') %>
<main class="p-12 lg:p-16 space-y-10" id="content">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 border-b border-white/5 pb-10">
        <div class="space-y-2">
            <div class="px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Plugin Manager</div>
            <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none"><%= instance.Name %></h2>
            <p class="text-zinc-500 text-sm">Browse, install and manage Minecraft plugins for this server.</p>
        </div>
        <div class="flex items-center gap-3 text-xs font-mono text-zinc-600">
            <span id="plugin-count" class="px-3 py-1 bg-white/[0.03] border border-white/5 rounded-lg">0 installed</span>
        </div>
    </div>

    <%- include('../components/instance') %>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">

        <!-- LEFT: Installed plugins -->
        <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <h3 class="text-sm font-black text-white uppercase tracking-widest">Installed</h3>
                <button onclick="loadInstalled()" class="text-[10px] font-bold text-zinc-500 hover:text-white uppercase tracking-widest transition flex items-center gap-1.5">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Refresh
                </button>
            </div>

            <div id="installed-list" class="flex flex-col gap-2 min-h-[200px]">
                <div class="flex items-center justify-center h-32 text-zinc-600 text-sm" id="installed-loading">
                    <svg class="w-5 h-5 animate-spin mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                    Loading...
                </div>
            </div>
        </div>

        <!-- RIGHT: Search Modrinth -->
        <div class="flex flex-col gap-4">
            <h3 class="text-sm font-black text-white uppercase tracking-widest">Browse Modrinth</h3>

            <div class="flex gap-2">
                <div class="flex-1 relative">
                    <input id="search-input" type="text" placeholder="Search plugins (e.g. EssentialsX, WorldEdit...)"
                        class="w-full px-4 py-3 bg-white/[0.03] border border-white/5 rounded-xl text-sm text-white placeholder:text-zinc-600 outline-none focus:border-emerald-500/40 transition"
                        onkeypress="if(event.key==='Enter') searchPlugins()">
                </div>
                <button onclick="searchPlugins()"
                    class="px-5 py-3 bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-black uppercase tracking-wider rounded-xl transition active:scale-95 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    Search
                </button>
            </div>

            <div id="search-results" class="flex flex-col gap-2 min-h-[200px]">
                <div class="flex items-center justify-center h-32 text-zinc-600 text-sm">
                    Search for a plugin above to get started.
                </div>
            </div>
        </div>
    </div>

</main>

<!-- Toast notification -->
<div id="toast" class="fixed bottom-6 right-6 z-50 hidden">
    <div id="toast-inner" class="px-5 py-3 rounded-xl border text-sm font-semibold flex items-center gap-3 shadow-2xl"></div>
</div>

<script>
    const instanceId = '<%= req.params.id %>';

    function showToast(msg, ok = true) {
        const t = document.getElementById('toast');
        const i = document.getElementById('toast-inner');
        i.className = `px-5 py-3 rounded-xl border text-sm font-semibold flex items-center gap-3 shadow-2xl ${
            ok ? 'bg-emerald-950 border-emerald-500/30 text-emerald-300' : 'bg-rose-950 border-rose-500/30 text-rose-300'}`;
        i.innerHTML = (ok
            ? '<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
            : '<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        ) + msg;
        t.classList.remove('hidden');
        clearTimeout(t._timer);
        t._timer = setTimeout(() => t.classList.add('hidden'), 3500);
    }

    function formatBytes(b) {
        if (b < 1024) return b + ' B';
        if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
        return (b / 1048576).toFixed(2) + ' MB';
    }

    async function loadInstalled() {
        const list = document.getElementById('installed-list');
        list.innerHTML = `<div class="flex items-center justify-center h-32 text-zinc-600 text-sm">
            <svg class="w-5 h-5 animate-spin mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>Loading...
        </div>`;
        try {
            const res = await fetch(`/instance/${instanceId}/plugins/list`);
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Failed');
            renderInstalled(data);
        } catch (e) {
            list.innerHTML = `<div class="flex items-center justify-center h-24 text-rose-400 text-sm">${e.message}</div>`;
        }
    }

    function renderInstalled(plugins) {
        const list = document.getElementById('installed-list');
        document.getElementById('plugin-count').textContent = plugins.length + ' installed';
        if (!plugins.length) {
            list.innerHTML = `<div class="flex flex-col items-center justify-center h-32 gap-2 text-zinc-600 text-sm">
                <svg class="w-8 h-8 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
                No plugins installed yet
            </div>`;
            return;
        }
        list.innerHTML = plugins.map(p => `
            <div class="flex items-center justify-between px-5 py-3.5 bg-white/[0.03] rounded-xl border border-white/5 group hover:border-white/10 transition">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-bold text-white truncate">${escHtml(p.name)}</p>
                        <p class="text-[10px] text-zinc-500 font-mono">${escHtml(p.filename)} &middot; ${formatBytes(p.size)}</p>
                    </div>
                </div>
                <button onclick="deletePlugin('${escAttr(p.filename)}')"
                    class="flex-shrink-0 w-8 h-8 rounded-lg border border-white/5 text-zinc-600 hover:text-rose-400 hover:border-rose-500/30 hover:bg-rose-500/5 flex items-center justify-center transition opacity-0 group-hover:opacity-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
            </div>`).join('');
    }

    async function deletePlugin(filename) {
        if (!confirm(`Remove ${filename}?`)) return;
        try {
            const res = await fetch(`/instance/${instanceId}/plugins/${encodeURIComponent(filename)}`, { method: 'DELETE' });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Failed');
            showToast('Plugin removed. Restart server to apply.');
            loadInstalled();
        } catch (e) {
            showToast(e.message, false);
        }
    }

    async function searchPlugins() {
        const q = document.getElementById('search-input').value.trim();
        if (!q) return;
        const results = document.getElementById('search-results');
        results.innerHTML = `<div class="flex items-center justify-center h-32 text-zinc-600 text-sm">
            <svg class="w-5 h-5 animate-spin mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>Searching Modrinth...
        </div>`;
        try {
            const url = `https://api.modrinth.com/v2/search?query=${encodeURIComponent(q)}&facets=${encodeURIComponent('[["project_type:plugin"]]')}&limit=15&index=downloads`;
            const res = await fetch(url, { headers: { 'User-Agent': 'VOLQ-Panel/1.0' } });
            const data = await res.json();
            renderResults(data.hits || []);
        } catch (e) {
            results.innerHTML = `<div class="flex items-center justify-center h-24 text-rose-400 text-sm">${e.message}</div>`;
        }
    }

    function renderResults(hits) {
        const results = document.getElementById('search-results');
        if (!hits.length) {
            results.innerHTML = `<div class="flex items-center justify-center h-24 text-zinc-600 text-sm">No plugins found.</div>`;
            return;
        }
        results.innerHTML = hits.map(h => `
            <div class="flex items-center gap-4 px-5 py-4 bg-white/[0.03] rounded-xl border border-white/5 hover:border-white/10 transition group">
                ${h.icon_url
                    ? `<img src="${escAttr(h.icon_url)}" class="w-10 h-10 rounded-xl flex-shrink-0 object-cover bg-zinc-900" onerror="this.style.display='none'">`
                    : `<div class="w-10 h-10 rounded-xl bg-zinc-800 flex items-center justify-center flex-shrink-0 text-zinc-500 text-xs font-bold">${escHtml(h.title.slice(0,2).toUpperCase())}</div>`}
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-white truncate">${escHtml(h.title)}</p>
                    <p class="text-[11px] text-zinc-500 truncate mt-0.5">${escHtml(h.description)}</p>
                    <div class="flex items-center gap-3 mt-1">
                        <span class="text-[10px] text-zinc-600">&#8595; ${Number(h.downloads).toLocaleString()} downloads</span>
                    </div>
                </div>
                <button onclick="installPlugin('${escAttr(h.project_id)}', '${escAttr(h.title)}')" id="btn-${escAttr(h.project_id)}"
                    class="flex-shrink-0 px-4 py-2 bg-emerald-600/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-black uppercase tracking-wider rounded-lg hover:bg-emerald-600 hover:text-white transition active:scale-95">
                    Install
                </button>
            </div>`).join('');
    }

    async function installPlugin(projectId, title) {
        const btn = document.getElementById('btn-' + projectId);
        if (btn) { btn.textContent = '...'; btn.disabled = true; }
        try {
            const vRes = await fetch(`https://api.modrinth.com/v2/project/${projectId}/version?limit=1`, {
                headers: { 'User-Agent': 'VOLQ-Panel/1.0' }
            });
            const versions = await vRes.json();
            if (!versions.length) throw new Error('No versions found');

            const version = versions[0];
            const jarFile = version.files.find(f => f.primary) || version.files.find(f => f.filename.endsWith('.jar')) || version.files[0];
            if (!jarFile) throw new Error('No JAR file found for this plugin');

            const res = await fetch(`/instance/${instanceId}/plugins/install`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: jarFile.url, filename: jarFile.filename })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Install failed');

            showToast(`${title} installed! Restart server to load it.`);
            if (btn) { btn.textContent = 'Installed'; btn.className = btn.className.replace('emerald', 'zinc'); }
            loadInstalled();
        } catch (e) {
            showToast(e.message, false);
            if (btn) { btn.textContent = 'Install'; btn.disabled = false; }
        }
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escAttr(s) {
        return String(s).replace(/'/g, "\\'");
    }

    document.addEventListener('DOMContentLoaded', loadInstalled);
</script>
<%- include('../components/footer') %>