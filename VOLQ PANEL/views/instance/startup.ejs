<%- include('../components/template') %>
<main class="p-4 sm:p-8 lg:p-16 space-y-8 lg:space-y-12" id="content">
    <!-- Header Protocol -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 border-b border-white/5 pb-10">
        <div class="space-y-2">
            <div class="px-3 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Initialization logic</div>
            <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none">Boot Parameters</h2>
            <p class="text-zinc-500 text-sm font-medium">Coordinate the orchestration environment and runtime variables for this unit.</p>
        </div>
    </div>

    <%- include('../components/instance') %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Image Selector -->
        <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-amber-500/10 border border-amber-500/20 rounded-xl flex items-center justify-center text-amber-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight leading-none">Virtualization Layer</h3>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest mt-1">Docker Environment Blueprint</p>
                </div>
            </div>

            <div class="space-y-6">
                <% if (instance.AltImages && instance.AltImages.length > 0) { %>
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Blueprint Registry</label>
                        <select id="image" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm outline-none focus:ring-1 focus:ring-amber-500/30 transition-all appearance-none cursor-pointer hover:bg-white/[0.05]">
                            <% instance.AltImages.forEach(function(alt) { %>
                                <option value="<%= alt %>" <%= instance.currentimage === alt ? 'selected' : '' %> class="bg-zinc-900"><%= alt %></option>
                            <% }); %>
                        </select>
                    </div>
                    <button id="save-image" class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-blue-500/20 active:scale-95">Commit Registry Shift</button>
                <% } else { %>
                    <p class="text-zinc-600 text-[10px] font-bold uppercase tracking-widest text-center py-8">No alternative blueprints authorized.</p>
                <% } %>
            </div>
        </div>

        <!-- Logic Variables -->
        <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-blue-500/10 border border-blue-500/20 rounded-xl flex items-center justify-center text-blue-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight leading-none">Runtime Matrix</h3>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest mt-1">Environment Variable Injection</p>
                </div>
            </div>

            <div class="space-y-8 max-h-[400px] overflow-y-auto pr-4 custom-scrollbar">
                <% 
                    const envMap = {};
                    if(instance.Env) instance.Env.forEach(e => { const [k,v] = e.split('='); envMap[k] = v; });
                %>

                <% if (instance.imageData && instance.imageData.Variables) { %>
                    <% Object.keys(instance.imageData.Variables).forEach(function(key) { %>
                        <% const v = instance.imageData.Variables[key]; %>
                        <div class="p-6 bg-white/[0.02] border border-white/5 rounded-3xl space-y-4 group hover:border-blue-500/20 transition-colors">
                            <div class="flex justify-between items-center">
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest"><%= key %></label>
                                <span class="text-[8px] font-black text-blue-500/40 uppercase tracking-tighter"><%= v.type %></span>
                            </div>
                            <input id="variable-<%= key %>" type="<%= v.type %>" value="<%= envMap[key] || '' %>" class="w-full px-5 py-3 bg-black/20 border border-white/5 rounded-xl text-white text-sm outline-none focus:ring-1 focus:ring-blue-500/30 transition-all placeholder:text-zinc-800">
                            <button id="save-variable-<%= key %>" class="px-6 py-2 bg-white/5 hover:bg-white text-zinc-400 hover:text-black text-[9px] font-black uppercase tracking-widest rounded-lg transition active:scale-95 ml-auto block">Synchronize</button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-zinc-600 text-[10px] font-bold uppercase tracking-widest text-center py-8">Static Environment Profile.</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Stability Protocol (moved from Settings) -->
    <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
        <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-center justify-center text-rose-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <div>
                <h3 class="text-lg font-bold text-white tracking-tight leading-none">Stability Protocol</h3>
                <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest mt-1">Instance Management</p>
            </div>
        </div>

        <div class="space-y-6">
            <div class="p-6 bg-white/[0.02] border border-white/5 rounded-3xl space-y-4">
                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Server Name</label>
                <div class="flex gap-3">
                    <input id="serverName" type="text" value="<%= instance.Name %>" class="flex-1 px-5 py-3 bg-black/20 border border-white/5 rounded-xl text-white text-sm outline-none focus:ring-1 focus:ring-blue-500/30 transition-all">
                    <button id="saveNameBtn" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-[9px] font-black uppercase tracking-widest rounded-xl transition active:scale-95">Save</button>
                </div>
            </div>

            <div class="p-6 bg-rose-500/5 border border-rose-500/10 rounded-3xl space-y-4">
                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Reinstalling will reset all server files to default. This action cannot be undone.</p>
                <form method="POST" action="/instance/reinstall/<%= instance.Id %>" onsubmit="return confirm('Are you sure? This will wipe all server files and reinstall from scratch.')">
                    <button type="submit" class="w-full py-4 bg-rose-600 hover:bg-rose-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-rose-500/20 active:scale-95">Reinstall Server</button>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
    // Save server name
    const saveNameBtn = document.getElementById('saveNameBtn');
    if (saveNameBtn) {
        saveNameBtn.onclick = () => {
            const name = document.getElementById('serverName').value.trim();
            if (name) {
                window.location.href = '/instance/<%= instance.Id %>/change/name/' + encodeURIComponent(name);
            }
        };
    }

    const saveImg = document.getElementById('save-image');
    if(saveImg) {
        saveImg.onclick = () => {
            const img = document.getElementById('image').value;
            window.location.href = `/instances/startup/changeimage/<%= instance.Id %>?image=${encodeURIComponent(img)}&user=<%= req.user.userId %>`;
        }
    }

    <% if (instance.imageData && instance.imageData.Variables) { %>
        <% Object.keys(instance.imageData.Variables).forEach(function(key) { %>
            document.getElementById('save-variable-<%= key %>').onclick = () => {
                const val = document.getElementById('variable-<%= key %>').value;
                fetch(`/instances/startup/changevariable/<%= instance.Id %>?variable=<%= key %>&value=${encodeURIComponent(val)}&user=<%= req.user.userId %>`, { method: 'POST' })
                .then(r => r.json()).then(d => alert(d.success ? 'MATRIX SYNCHRONIZED' : 'SYNCHRONIZATION FAILED'));
            };
        <% }); %>
    <% } %>
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(59,130,246,0.2); }
</style>
<%- include('../components/footer') %>