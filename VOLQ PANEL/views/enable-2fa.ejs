<%- include('components/template') %>
<main class="min-h-[80vh] flex items-center justify-center p-6 lg:p-12" id="content">
    <div class="liquid-glass p-12 lg:p-16 rounded-[4rem] border border-white/5 shadow-4xl max-w-md w-full text-center space-y-10 relative overflow-hidden">
        <!-- Structural Background Glows -->
        <div class="absolute -left-20 -top-20 w-64 h-64 bg-blue-600/5 rounded-full blur-[80px]"></div>
        <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-blue-600/5 rounded-full blur-[80px]"></div>

        <div class="relative z-10 space-y-8">
            <div class="w-20 h-20 bg-blue-500/10 border border-blue-500/20 rounded-[2rem] flex items-center justify-center text-blue-500 mx-auto shadow-2xl shadow-blue-500/10">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>

            <div class="space-y-4">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[10px] font-black rounded-xl w-max mx-auto tracking-[0.3em] uppercase">Security Protocol</div>
                <h2 class="text-3xl font-black text-white tracking-tight leading-none uppercase">Identity Sync</h2>
                <p class="text-zinc-500 text-xs font-medium leading-relaxed max-w-[280px] mx-auto">Coordinate a two-factor authentication token to secure your administrative clearance.</p>
            </div>

            <div class="flex justify-center group">
                <div class="p-6 bg-white rounded-[2.5rem] shadow-3xl group-hover:scale-105 transition-transform duration-500 relative">
                    <img src="<%= qrCode %>" alt="QR Code" class="w-44 h-44 rounded-xl grayscale group-hover:grayscale-0 transition-all duration-700">
                    <div class="absolute inset-0 border-4 border-white rounded-[2.5rem]"></div>
                </div>
            </div>

            <form action="/verify-2fa" method="POST" class="space-y-8">
                <div class="space-y-2 text-left">
                    <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Synchronization Code</label>
                    <input type="text" name="token" required placeholder="000 000" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-center text-sm font-black tracking-[0.3em] focus:ring-1 focus:ring-blue-500/30 outline-none transition-all placeholder:text-zinc-800">
                </div>

                <div class="flex gap-4">
                    <a href="/account" class="flex-1 py-4 bg-white/5 hover:bg-white/10 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl transition active:scale-95">Decline</a>
                    <button type="submit" class="flex-1 py-4 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl transition shadow-3xl shadow-blue-500/20 active:scale-95">Sync Token</button>
                </div>
            </form>
        </div>
    </div>
</main>
<%- include('components/footer') %>