<%- include('../components/template') %>
<main class="p-12 lg:p-16">
    <div class="max-w-4xl mx-auto space-y-12">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/5 pb-12">
            <div class="space-y-2">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Security Directive</div>
                <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none"><%= req.translations.editUser %></h2>
                <p class="text-zinc-500 text-sm font-medium"><%= req.translations.editUserDetails %></p>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center text-blue-500 shadow-2xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </div>
            </div>
        </div>

        <!-- Interface -->
        <div class="liquid-glass rounded-[3rem] p-12 border border-white/5 shadow-2xl relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-80 h-80 bg-blue-600/5 rounded-full blur-[100px]"></div>
            
            <form action="/admin/users/edit/<%= editUser.userId %>" method="POST" class="space-y-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2"><%= req.translations.username %></label>
                            <input id="userName" name="username" type="text" value="<%= editUser.username %>" placeholder="<%= req.translations.usernamePlaceholder %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all placeholder:text-zinc-700">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2"><%= req.translations.email %></label>
                            <input id="email" name="email" type="email" value="<%= editUser.email %>" placeholder="<%= req.translations.emailPlaceholder %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all placeholder:text-zinc-700">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2"><%= req.translations.passwordLabel %></label>
                            <input id="userPass" name="password" type="password" placeholder="••••••••" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all placeholder:text-zinc-700">
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Administrative Status</label>
                            <select name="admin" class="w-full px-5 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm appearance-none focus:ring-1 focus:ring-blue-500/30 outline-none">
                                <option value="true" class="bg-zinc-900" <%= editUser.admin ? 'selected' : '' %>><%= req.translations.true %></option>
                                <option value="false" class="bg-zinc-900" <%= !editUser.admin ? 'selected' : '' %>><%= req.translations.false %></option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Verification Protocol</label>
                            <select name="verified" class="w-full px-5 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm appearance-none focus:ring-1 focus:ring-blue-500/30 outline-none">
                                <option value="true" class="bg-zinc-900" <%= editUser.verified ? 'selected' : '' %>><%= req.translations.true %></option>
                                <option value="false" class="bg-zinc-900" <%= !editUser.verified ? 'selected' : '' %>><%= req.translations.false %></option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="pt-10 border-t border-white/[0.03] flex flex-col sm:flex-row gap-4">
                    <button type="submit" class="px-10 py-5 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-[2rem] transition shadow-3xl shadow-blue-500/20 active:scale-95">
                        Update Security Identity
                    </button>
                    <button type="button" onclick="location.href='/admin/users'" class="px-10 py-5 bg-white/5 border border-white/10 text-zinc-500 hover:text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-[2rem] transition">
                        Cancel Change
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>
<%- include('../components/footer') %>