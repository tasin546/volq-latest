<%- include('../../components/template') %>
<main class="p-12 lg:p-16">
    <div class="max-w-7xl mx-auto space-y-10">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div class="space-y-2">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">System Core</div>
                <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none"><%= req.translations.settings %></h2>
                <p class="text-zinc-500 text-sm font-medium"><%= req.translations.changeSettings %></p>
            </div>
        </div>

        <%- include('../../components/settings') %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
            <!-- General Settings -->
            <div class="liquid-glass rounded-[3rem] p-10 border border-white/5 shadow-2xl relative overflow-hidden space-y-8">
                <div class="flex items-center gap-4 mb-2">
                    <div class="w-10 h-10 rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center text-zinc-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <h3 class="text-xl font-bold text-white"><%= req.translations.general %></h3>
                </div>

                <form action="/admin/settings/change/name" method="POST" class="space-y-6">
                    <div>
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2"><%= req.translations.panelName %></label>
                        <div class="flex gap-3">
                            <input id="name" name="name" type="text" class="flex-1 px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all placeholder:text-zinc-700" value="<%= name %>" required>
                            <button type="submit" class="px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-2xl transition shadow-xl shadow-blue-500/20 active:scale-95">
                                <%= req.translations.save %>
                            </button>
                        </div>
                    </div>
                </form>

                <div class="pt-8 border-t border-white/[0.03] space-y-6">
                    <form action="/admin/settings/toggle/register" method="POST" class="flex items-center justify-between p-4 bg-white/[0.01] border border-white/5 rounded-2xl">
                        <div>
                            <p class="text-xs font-bold text-white mb-1"><%= req.translations.registerPage %></p>
                            <p class="text-[10px] font-bold uppercase tracking-widest <%= settings.register ? 'text-emerald-500' : 'text-rose-500' %>">
                                <%= settings.register ? req.translations.enabled : req.translations.disabled %>
                            </p>
                        </div>
                        <button type="submit" class="px-6 py-2.5 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl text-[10px] font-bold text-white transition active:scale-95 uppercase tracking-widest">
                            <%= settings.register ? req.translations.disable : req.translations.enable %>
                        </button>
                    </form>

                    <form action="/admin/settings/toggle/force-verify" method="POST" class="flex items-center justify-between p-4 bg-white/[0.01] border border-white/5 rounded-2xl">
                        <div>
                            <p class="text-xs font-bold text-white mb-1"><%= req.translations.forceVerifyEmail %></p>
                            <p class="text-[10px] font-bold uppercase tracking-widest <%= settings.forceVerify ? 'text-emerald-500' : 'text-rose-500' %>">
                                <%= settings.forceVerify ? req.translations.enabled : req.translations.disabled %>
                            </p>
                        </div>
                        <button type="submit" class="px-6 py-2.5 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl text-[10px] font-bold text-white transition active:scale-95 uppercase tracking-widest">
                            <%= settings.forceVerify ? req.translations.disable : req.translations.enable %>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Logo Section -->
            <div id="changelogoform" class="liquid-glass rounded-[3rem] p-10 border border-white/5 shadow-2xl space-y-8">
                <div class="flex items-center gap-4 mb-2">
                    <div class="w-10 h-10 rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center text-zinc-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    </div>
                    <h3 class="text-xl font-bold text-white"><%= req.translations.panelLogo %></h3>
                </div>

                <form action="/admin/settings/change/logo" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <div class="group relative w-24 h-24 mx-auto mb-8">
                        <div class="absolute inset-0 bg-blue-500/20 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="relative w-full h-full bg-white/[0.03] border border-white/10 rounded-3xl flex items-center justify-center overflow-hidden">
                            <% if (logo == true) { %>
                                <img src="/assets/logo.png" class="w-full h-full object-cover">
                            <% } else { %>
                                <span class="text-2xl font-black text-zinc-700">V</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex items-center gap-3 px-4 py-3 bg-white/[0.01] border border-white/5 rounded-2xl cursor-pointer hover:bg-white/5 transition-colors">
                            <input id="useImage" type="checkbox" class="w-5 h-5 bg-transparent border-white/10 rounded-lg text-blue-600 focus:ring-blue-500/30">
                            <label for="useImage" class="text-xs font-bold text-zinc-400 uppercase tracking-widest cursor-pointer">Use Custom Image</label>
                        </div>

                        <div id="imageUploadBox" class="hidden animate-in fade-in slide-in-from-top-2">
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Upload Asset</label>
                            <input type="file" name="logo" id="logo" accept="image/*" class="w-full text-xs text-zinc-500 file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-[10px] file:font-bold file:uppercase file:tracking-widest file:bg-blue-600/10 file:text-blue-500 hover:file:bg-blue-600/20 transition-all cursor-pointer">
                        </div>
                    </div>

                    <input type="hidden" name="type" id="logoType" value="none">
                    <button id="logoButton" type="submit" class="w-full py-4 bg-white/5 border border-white/10 text-white text-xs font-bold rounded-2xl transition hover:bg-white/10 active:scale-95 shadow-xl">
                        <%= req.translations.removeLogo %>
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
   document.getElementById('useImage').addEventListener('change', function() {
     const imageUploadBox = document.getElementById('imageUploadBox');
     const logoButton = document.getElementById('logoButton');
     const logoType = document.getElementById('logoType');
     
     if (this.checked) {
       imageUploadBox.classList.remove('hidden');
       logoButton.textContent = '<%= req.translations.saveNewLogo %>';
       logoButton.classList.replace('bg-white/5', 'bg-blue-600');
       logoButton.classList.add('shadow-blue-500/20');
       logoType.value = 'image';
     } else {
       imageUploadBox.classList.add('hidden');
       logoButton.textContent = '<%= req.translations.removeLogo %>';
       logoButton.classList.replace('bg-blue-600', 'bg-white/5');
       logoButton.classList.remove('shadow-blue-500/20');
       logoType.value = 'none';
     }
   });
</script>
<%- include('../../components/footer') %>
