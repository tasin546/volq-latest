<%- include('../components/template') %>
<main class="p-12 lg:p-16">
    <div class="max-w-5xl mx-auto space-y-12">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/5 pb-12">
            <div class="space-y-2">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Compute Node Configuration</div>
                <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none">Edit Node: <%- node.name %></h2>
                <p class="text-zinc-500 text-sm font-medium">Coordinate the administrative parameters and security keys for this hardware unit.</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center text-blue-500 shadow-2xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
                </div>
            </div>
        </div>

        <!-- Interface Grid -->
        <div class="liquid-glass rounded-[3rem] p-12 border border-white/5 shadow-2xl relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-80 h-80 bg-blue-600/5 rounded-full blur-[100px]"></div>
            
            <form id="nodeForm" class="space-y-12">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <!-- Primary Config -->
                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Node Alias</label>
                            <input id="nodeName" type="text" value="<%- node.name %>" placeholder="Production-01" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Metadata Tags</label>
                            <input id="nodeTags" type="text" value="<%- node.tags %>" placeholder="NVME - DDR5 - EPYC" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">RAM (GB)</label>
                                <input id="nodeRam" type="number" value="<%- node.ram %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Disk (GB)</label>
                                <input id="nodeDisk" type="number" value="<%- node.disk %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                            </div>
                        </div>
                    </div>

                    <!-- Network & Auth -->
                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Processor Logic</label>
                            <input id="nodeProcessor" type="text" value="<%- node.processor %>" placeholder="Intel Xeon Gold" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                        </div>
                        <div class="grid grid-cols-3 gap-4">
                            <div class="col-span-2">
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Network Origin</label>
                                <input id="nodeAddress" type="text" value="<%- node.address %>" placeholder="127.0.0.1" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Port</label>
                                <input id="nodePort" type="number" value="<%- node.port %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] block mb-3 ml-2">Secure Access Key</label>
                            <input id="nodeApiKey" type="password" value="<%- node.apiKey %>" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-[10px] font-mono tracking-widest focus:ring-1 focus:ring-blue-500/30 outline-none transition-all">
                        </div>
                    </div>
                </div>

                <div class="pt-10 border-t border-white/[0.03] flex flex-col sm:flex-row gap-6">
                    <button id="saveNodeBtn" type="button" class="px-12 py-5 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-[2rem] transition shadow-3xl shadow-blue-500/20 active:scale-95">
                        Apply Directives
                    </button>
                    <button type="button" onclick="location.href='/admin/nodes'" class="px-12 py-5 bg-white/5 border border-white/10 text-zinc-500 hover:text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-[2rem] transition">
                        Abort Protocol
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

<script>
document.getElementById('saveNodeBtn').onclick = async function() {
    const btn = this;
    btn.textContent = 'SYNCHRONIZING...';
    btn.disabled = true;

    const nodeData = {
        name: document.getElementById('nodeName').value,
        tags: document.getElementById('nodeTags').value.split('-'),
        ram: document.getElementById('nodeRam').value,
        disk: document.getElementById('nodeDisk').value,
        processor: document.getElementById('nodeProcessor').value,
        address: document.getElementById('nodeAddress').value,
        port: document.getElementById('nodePort').value,
        apiKey: document.getElementById('nodeApiKey').value
    };

    try {
        const res = await fetch('/admin/node/<%- node.id %>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(nodeData)
        });
        if(res.ok) window.location.href = '../nodes?err=EDITED';
        else throw new Error();
    } catch(e) {
        alert('Synchronization failure.');
        btn.textContent = 'Apply Directives';
        btn.disabled = false;
    }
};
</script>
<%- include('../components/footer') %>
