<%- include('../components/template') %>
<main class="p-12 lg:p-16">
    <div class="max-w-7xl mx-auto space-y-12">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/5 pb-12">
            <div class="space-y-2">
                <div class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[9px] font-bold rounded-lg w-max mb-2 tracking-tighter uppercase leading-none">Compute Telemetry</div>
                <h2 class="text-4xl font-extrabold tracking-tight text-white leading-none">Node Performance</h2>
                <p class="text-zinc-500 text-sm font-medium">Real-time resource utilization and hardware health monitoring for <%- node.name %>.</p>
            </div>
            <button onclick="location.href='/admin/nodes'" class="px-8 py-3 bg-white/[0.03] border border-white/5 hover:border-white/10 text-white text-[10px] font-bold rounded-2xl transition uppercase tracking-widest">
                Return to Registry
            </button>
        </div>

        <!-- Metric Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
                <div class="absolute -right-16 -top-16 w-48 h-48 bg-blue-600/5 rounded-full blur-[60px]"></div>
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Fleet Density</span>
                <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-black text-white"><%= Object.values(set).reduce((a, b) => a + b, 0) %></span>
                    <span class="text-[9px] text-zinc-600 font-bold uppercase tracking-widest leading-none">Units</span>
                </div>
            </div>

            <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
                <div class="absolute -right-16 -top-16 w-48 h-48 bg-emerald-600/5 rounded-full blur-[60px]"></div>
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Active Stream</span>
                <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-black text-white"><%= stats.onlineContainersCount || 0 %></span>
                    <span class="text-[9px] text-zinc-600 font-bold uppercase tracking-widest leading-none">Online</span>
                </div>
            </div>

            <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
                <div class="absolute -right-16 -top-16 w-48 h-48 bg-purple-600/5 rounded-full blur-[60px]"></div>
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Temporal Drift</span>
                <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-black text-white"><%= stats.uptime || '0m' %></span>
                </div>
            </div>

            <div class="liquid-glass p-8 rounded-[2.5rem] border border-white/5 relative overflow-hidden group">
                <div class="absolute -right-16 -top-16 w-48 h-48 bg-blue-400/5 rounded-full blur-[60px]"></div>
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4 block">Protocol State</span>
                <div class="flex items-center gap-3">
                    <div class="w-3 h-3 rounded-full <%= status === 'Online' ? 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]' : 'bg-rose-500 shadow-[0_0_10px_rgba(244,63,94,0.5)]' %> animate-pulse"></div>
                    <span class="text-xl font-black text-white uppercase tracking-tighter"><%= status %></span>
                </div>
            </div>
        </div>

        <!-- Charts Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-white uppercase tracking-widest">Memory Saturation</h3>
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
                </div>
                <div class="relative h-[300px]">
                    <canvas id="ramChart"></canvas>
                </div>
            </div>

            <div class="liquid-glass p-10 rounded-[3rem] border border-white/5 shadow-2xl space-y-8">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-white uppercase tracking-widest">Processor Intensity</h3>
                    <div class="w-1.5 h-1.5 rounded-full bg-rose-500"></div>
                </div>
                <div class="relative h-[300px]">
                    <canvas id="cpuChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Detail Registry -->
        <div class="liquid-glass rounded-[2.5rem] overflow-hidden border border-white/5 shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/[0.02] border-b border-white/5">
                            <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Hardware ID</th>
                            <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Network Blueprint</th>
                            <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Unit Count</th>
                            <th class="px-8 py-5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-right">Operations</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/[0.02]">
                        <tr class="hover:bg-white/[0.01] transition-colors group">
                            <td class="px-8 py-6">
                                <span class="text-xs font-bold text-white uppercase tracking-tight"><%= node.name %></span>
                            </td>
                            <td class="px-8 py-6">
                                <div class="px-4 py-2 bg-black/40 border border-white/5 rounded-xl text-[11px] font-mono text-zinc-400 group-hover:border-blue-500/30 transition-colors w-max">
                                    <%= node.address %>:<%= node.port %>
                                </div>
                            </td>
                            <td class="px-8 py-6">
                                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest"><%= set[node.id] || 0 %> ACTIVE</span>
                            </td>
                            <td class="px-8 py-6 text-right">
                                <button onclick="location.href='/admin/node/<%= node.id %>'" class="px-6 py-2 bg-blue-600 hover:bg-blue-500 text-white text-[9px] font-black uppercase tracking-widest rounded-xl transition shadow-xl shadow-blue-500/20 active:scale-95">
                                    Control
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const history = <%- JSON.stringify(stats.totalStats) || '[]' %>;
    const parseVal = (s, r) => parseFloat(s.replace(r, ''));
    
    const labels = history.length ? history.map(s => new Date(s.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})) : ['00:00', '00:00', '00:00'];
    const ramData = history.length ? history.map(s => parseVal(s.Ram, ' MB')) : [0,0,0];
    const cpuData = history.length ? history.map(s => parseVal(s.Cores, '%')) : [0,0,0];

    const opt = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.03)' }, ticks: { color: '#52525b', font: { weight: 'bold', size: 10 } } },
            x: { grid: { display: false }, ticks: { color: '#52525b', font: { weight: 'bold', size: 10 } } }
        }
    };

    new Chart(document.getElementById('ramChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                data: ramData,
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 3,
                pointRadius: 0
            }]
        },
        options: opt
    });

    new Chart(document.getElementById('cpuChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                data: cpuData,
                borderColor: '#f43f5e',
                backgroundColor: 'rgba(244, 63, 94, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 3,
                pointRadius: 0
            }]
        },
        options: opt
    });
</script>
<%- include('../components/footer') %>
