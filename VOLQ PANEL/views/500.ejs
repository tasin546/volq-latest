<%- include('components/template') %>
<main class="min-h-[80vh] flex items-center justify-center p-6 lg:p-12" id="content">
    <div class="liquid-glass p-16 rounded-[4rem] border border-white/5 shadow-4xl max-w-2xl w-full text-center space-y-10 relative overflow-hidden">
        <!-- Structural Background Glows -->
        <div class="absolute -left-20 -top-20 w-64 h-64 bg-rose-600/5 rounded-full blur-[80px]"></div>
        <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-rose-600/5 rounded-full blur-[80px]"></div>

        <div class="relative z-10 space-y-8">
            <div class="w-24 h-24 bg-rose-500/10 border border-rose-500/20 rounded-[2.5rem] flex items-center justify-center text-rose-500 mx-auto shadow-2xl shadow-rose-500/20">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>

            <div class="space-y-4">
                <div class="px-3 py-1 bg-rose-500/10 border border-rose-500/20 text-rose-500 text-[10px] font-black rounded-xl w-max mx-auto tracking-[0.3em] uppercase">Anomaly Detected</div>
                <h2 class="text-5xl font-black text-white tracking-tight leading-none uppercase">System Handshake Ruptured</h2>
                <p class="text-zinc-500 text-lg font-medium leading-relaxed max-w-md mx-auto">The infrastructure encountered an unforeseen execution logic deviation.</p>
            </div>

            <div class="p-6 bg-black/40 border border-white/5 rounded-3xl text-left space-y-3">
                <p class="text-[10px] font-black text-rose-500 uppercase tracking-widest leading-none">Diagnostic Trace</p>
                <code class="text-zinc-400 font-mono text-xs break-all block leading-relaxed"><%= error || "NO_METADATA_AVAILABLE" %></code>
            </div>

            <div class="h-px w-full bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

            <div class="space-y-6">
                <p class="text-[10px] font-black text-zinc-600 uppercase tracking-[0.3em]">Operational recovery protocol</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <button onclick="window.location.reload()" class="px-10 py-4 bg-white/5 hover:bg-white text-zinc-400 hover:text-black text-[10px] font-black uppercase tracking-widest rounded-2xl transition shadow-3xl active:scale-95">Re-Synchronize</button>
                    <a href="/" class="px-10 py-4 bg-rose-600 hover:bg-rose-500 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl transition shadow-3xl shadow-rose-500/20 active:scale-95">Return to Cluster</a>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('components/footer') %>