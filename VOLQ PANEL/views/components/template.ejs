            <!-- Plugin items -->
            <% if (plugins && plugins.length > 0) { %>
            <div class="pt-6">
                <div class="mb-4 px-5">
                    <span class="text-[10px] font-bold text-zinc-700 uppercase tracking-widest leading-none">Extensions</span>
                </div>
                <% plugins.forEach(plugin => { %>
                    <% if (plugin.sidebar) { %>
                        <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                            <a href="<%= value.url %>" class="nav-item-glass flex items-center gap-4 px-5 py-3.5 rounded-2xl text-zinc-500 group <%= req.path === value.url ? 'active' : '' %>">
                                <div class="p-2 rounded-xl bg-white/2 border border-white/5 transition-all group-hover:border-white/20">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                                </div>
                                <span class="text-xs font-semibold"><%= key %></span>
                            </a>
