        <!-- Topbar -->
        <header class="h-16 flex items-center justify-between px-4 sm:px-10 z-40 bg-black/10 backdrop-blur-3xl border-b border-white/[0.03]">
            <button onclick="toggleSidebar()" class="lg:hidden p-2 text-zinc-400 hover:text-white transition mr-2 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
            <div class="relative w-full max-sm px-4">
                <span class="absolute inset-y-0 left-4 pl-4 flex items-center pointer-events-none text-zinc-700">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </span>
                <input id="searchInput" type="text" class="block w-full pl-10 pr-4 py-1.5 border border-white/5 rounded-2xl bg-white/[0.02] text-zinc-200 text-xs focus:ring-1 focus:ring-blue-500/20 outline-none transition-all placeholder:text-zinc-700" placeholder="<%= req.translations.search %>">
                <div id="searchResults" class="absolute bg-[#18181b] w-full rounded-2xl shadow-2xl hidden mt-2 z-50 border border-white/10 p-2 max-h-96 overflow-y-auto"></div>
            </div>
            
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-10 text-[10px] font-bold text-zinc-600 uppercase tracking-[0.2em] hidden md:flex">
                    <a href="https://volq.xyz/" target="_blank" class="hover:text-blue-400 transition">Docs</a>
                    <a href="https://discord.gg/DdNRaGgqqD" target="_blank" class="hover:text-blue-400 transition">Discord</a>
                </div>
                <a href="/auth/logout" class="px-7 py-2 bg-white hover:bg-zinc-100 text-zinc-950 text-[11px] font-bold rounded-2xl transition shadow-xl shadow-white/5 active:scale-95 whitespace-nowrap flex-shrink-0">Sign Out</a>
            </div>
        </header>

        <!-- Dynamic Content area -->
        <div id="content" class="flex-1 overflow-y-auto scroll-smooth transition-opacity duration-300">

    <div id="statusModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-xl z-[100] flex justify-center items-center p-6 animate-in fade-in duration-300">
        <div class="liquid-glass rounded-[4rem] p-16 max-w-lg w-full border border-white/5 shadow-4xl text-center space-y-10 relative overflow-hidden">
            <div id="modalGlow" class="absolute -right-16 -top-16 w-64 h-64 opacity-20 rounded-full blur-[80px]"></div>
            <div id="modalIcon" class="w-24 h-24 rounded-[2.5rem] flex items-center justify-center mx-auto border transition-all duration-500"></div>
            <div class="space-y-4">
                <h3 id="modalTitle" class="text-3xl font-black text-white tracking-tight leading-none uppercase"></h3>
                <p id="modalMsg" class="text-zinc-500 text-sm font-medium leading-relaxed max-w-xs mx-auto"></p>
            </div>
            <button id="closeModalBtn" class="w-full py-5 bg-white hover:bg-zinc-100 text-black font-black text-[10px] uppercase tracking-[0.2em] rounded-3xl transition active:scale-95 shadow-3xl">Dismiss Communication</button>
        </div>
    </div>

    <script>
        function showStatusModal(title, msg, type = 'success') {
            const modal = document.getElementById('statusModal');
            const icon = document.getElementById('modalIcon');
            const glow = document.getElementById('modalGlow');
            const titleEl = document.getElementById('modalTitle');
            const msgEl = document.getElementById('modalMsg');
            const btn = document.getElementById('closeModalBtn');

            titleEl.textContent = title;
            msgEl.textContent = msg;
            
            if(type === 'success') {
                icon.className = "w-24 h-24 rounded-[2.5rem] flex items-center justify-center mx-auto border border-emerald-500/20 bg-emerald-500/10 text-emerald-500";
                icon.innerHTML = '<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
                glow.className = "absolute -right-16 -top-16 w-64 h-64 bg-emerald-600 rounded-full blur-[80px] opacity-20";
            } else {
                icon.className = "w-24 h-24 rounded-[2.5rem] flex items-center justify-center mx-auto border border-rose-500/20 bg-rose-500/10 text-rose-500";
                icon.innerHTML = '<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>';
                glow.className = "absolute -right-16 -top-16 w-64 h-64 bg-rose-600 rounded-full blur-[80px] opacity-20";
            }

            modal.classList.remove('hidden');
            btn.onclick = () => modal.classList.add('hidden');
        }
        window.alert = function(msg) { showStatusModal('System Message', msg, 'success'); };
    </script>
