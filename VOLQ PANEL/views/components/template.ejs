<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name || 'VOLQ' %></title>
    <link rel="icon" href="/assets/logo.png" type="image/png">
    <link rel="shortcut icon" href="/assets/logo.png" type="image/png">


    
    <meta content="<%= ogTitle %>" property="og:title">
    <meta content="<%= ogDescription %>" property="og:description">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,600,400,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.02);
            --glass-border: rgba(255, 255, 255, 0.06);
            --glass-active: rgba(59, 130, 246, 0.12);
            --accent-blue: #3b82f6;
            --base-bg: #111114;
        }

        body {
            font-family: 'General Sans', sans-serif;
            background-color: var(--base-bg);
            background-image: 
                radial-gradient(circle at 85% 15%, rgba(59, 130, 246, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 15% 85%, rgba(37, 99, 235, 0.04) 0%, transparent 40%);
            background-attachment: fixed;
            color: #f4f4f5;
            -webkit-font-smoothing: antialiased;
        }
        
        .sidebar {
            background: rgba(0, 0, 0, 0.15);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border-right: 1px solid rgba(255, 255, 255, 0.04);
            border-left: none;
        }

        [data-sidebar-direction="right"] .sidebar {
            border-right: none;
            border-left: 1px solid rgba(255, 255, 255, 0.04);
        }

        .liquid-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.4);
        }

        .nav-item-glass {
            transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        }
        
        .nav-item-glass:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #fff;
            transform: translateX(8px);
        }

        .nav-item-glass.active {
            background: var(--glass-active);
            color: #fff;
            border-left: 3px solid var(--accent-blue);
        }

        /* Shine effect */
        .glass-shine {
            position: relative;
            overflow: hidden;
        }
        .glass-shine::after {
            content: '';
            position: absolute;
            top: -100%;
            left: -100%;
            width: 300%;
            height: 300%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.04), transparent);
            transform: rotate(45deg);
            transition: 0.8s ease-in-out;
        }
        .glass-shine:hover::after {
            left: 150%;
        }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 20px; }

        .loading-spin svg {
            fill: #868686;
        }
        @keyframes pulse-loader {
            50% { fill: #868686; }
            to { fill: rgba(134,134,134,.4); }
        }
        .loading-spin svg path {
            animation: pulse-loader 1s infinite linear;
        }
    </style>
</head>
