<!DOCTYPE html>
<html lang="en" class="h-full bg-[#111114]">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %> | Registration Phase</title>
    <link rel="icon" href="/assets/logo.png" type="image/x-icon">
    <link rel="shortcut icon" href="/assets/logo.png" type="image/x-icon">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,600,400,700,800&display=swap" rel="stylesheet">
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.06);
            --accent-blue: #3b82f6;
            --base-bg: #09090b;
        }
        body {
            font-family: 'General Sans', sans-serif;
            background-color: var(--base-bg);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(37, 99, 235, 0.06) 0%, transparent 40%);
            background-attachment: fixed;
            -webkit-font-smoothing: antialiased;
        }
        .liquid-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(32px);
            -webkit-backdrop-filter: blur(32px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .input-glass {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .input-glass:focus {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(59, 130, 246, 0.3);
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.1);
        }
    </style>
</head>
<body class="h-full flex items-center justify-center p-6 lg:p-12 overflow-hidden selection:bg-blue-500/30 selection:text-white">
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[-5%] left-[-5%] w-[60rem] h-[60rem] bg-indigo-600/5 rounded-full blur-[140px]"></div>
    </div>

    <div class="w-full max-w-[550px] relative z-10">
        <div class="liquid-glass p-12 lg:p-16 rounded-[4rem] relative group border border-white/10">
            <div class="relative z-10 space-y-10">
                <div class="space-y-4 text-center">
                    <img src="/assets/logo.png" alt="Logo" class="w-14 h-14 rounded-[1.8rem] shadow-3xl shadow-blue-500/30 mx-auto mb-6">
                    <div class="px-4 py-1.5 bg-blue-500/10 border border-blue-500/20 text-blue-500 text-[10px] font-black rounded-xl w-max tracking-[0.2em] uppercase mx-auto">
                        Registry Interface
                    </div>
                    <h2 class="text-4xl font-black text-white tracking-tight leading-none">Create Account</h2>
                    <p class="text-zinc-500 text-sm font-medium">Provision new operator coordinates for the cluster.</p>
                </div>

                <form action="/auth/register" method="POST" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] ml-2">Operator ID</label>
                        <input name="username" type="text" placeholder="Desired Username" required class="input-glass w-full px-7 py-4 rounded-2xl text-white text-sm outline-none placeholder:text-zinc-800">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] ml-2">Email Address</label>
                        <input name="email" type="email" placeholder="operator@domain.sh" required class="input-glass w-full px-7 py-4 rounded-2xl text-white text-sm outline-none placeholder:text-zinc-800">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] ml-2">Access Cipher</label>
                        <input name="password" type="password" placeholder="••••••••••••" required class="input-glass w-full px-7 py-4 rounded-2xl text-white text-sm outline-none placeholder:text-zinc-800">
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full py-5 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-[0.3em] rounded-2xl transition shadow-3xl shadow-blue-500/20 active:scale-[0.98]">
                            Finalize Enrollment
                        </button>
                    </div>

                    <div class="pt-6 text-center border-t border-white/5">
                        <span class="text-[10px] font-bold text-zinc-600 uppercase tracking-widest leading-none">Existing Active?</span>
                        <a href="/login" class="text-[10px] font-extrabold text-blue-500 hover:text-blue-400 uppercase tracking-widest ml-3 transition-colors">Authorize Session</a>
                    </div>

                    <% if (req.query.err) { %>
                        <div class="text-center pt-2">
                            <span class="text-rose-500 text-[10px] font-black uppercase tracking-[0.2em]">
                                Registry Error: <%= req.query.err.toUpperCase() %>
                            </span>
                        </div>
                    <% } %>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
