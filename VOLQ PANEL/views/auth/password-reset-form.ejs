<!DOCTYPE html>
<html class="h-full bg-[#111114]">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %> | Cipher Configuration</title>
    <link href="/assets/tailwind.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        .liquid-glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
        }
        body { font-family: 'Public Sans', sans-serif; }
    </style>
</head>
<body class="bg-[#111114] h-full flex items-center justify-center p-6 overflow-hidden">
    <!-- Atmospheric Elements -->
    <div class="fixed inset-0 pointer-events-none">
        <div class="absolute top-[-10%] right-[-10%] w-[50rem] h-[50rem] bg-indigo-600/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[50rem] h-[50rem] bg-zinc-600/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-[500px] relative z-10">
        <!-- Input Card -->
        <div class="liquid-glass p-12 lg:p-16 rounded-[3rem] border border-white/5 shadow-3xl relative overflow-hidden group">
            <div class="relative z-10 space-y-10">
                <div class="space-y-4 text-center">
                    <div class="w-12 h-12 bg-zinc-800 rounded-2xl flex items-center justify-center font-black text-white text-xl mx-auto mb-6 border border-white/10 shadow-3xl">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                    </div>
                    <div class="space-y-2">
                        <div class="px-3 py-1 bg-white/5 border border-white/10 text-zinc-400 text-[9px] font-bold rounded-lg w-max mx-auto tracking-tighter uppercase">Security Directive</div>
                        <h2 class="text-3xl font-extrabold text-white tracking-tight leading-none">New Master Cipher</h2>
                        <p class="text-zinc-500 text-sm font-medium leading-relaxed">Establish a high-entropy credential for your administrative identity.</p>
                    </div>
                </div>

                <form action="/auth/reset/<%= token %>" method="POST" class="space-y-8" id="resetPasswordForm">
                    <div class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">New Cipher</label>
                            <input id="password" name="password" type="password" placeholder="••••••••" required minlength="8" class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-white/20 outline-none transition-all placeholder:text-zinc-800">
                        </div>

                        <div class="space-y-2">
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Confirm Protocol</label>
                            <input id="confirm-password" name="confirm-password" type="password" placeholder="••••••••" required class="w-full px-6 py-4 bg-white/[0.03] border border-white/5 rounded-2xl text-white text-sm focus:ring-1 focus:ring-white/20 outline-none transition-all placeholder:text-zinc-800">
                        </div>
                    </div>

                    <!-- Entropy Meter -->
                    <div class="space-y-3">
                        <div class="flex justify-between items-center px-1">
                            <span class="text-[9px] font-bold text-zinc-600 uppercase tracking-widest">Cipher Entropy</span>
                            <span id="password-strength-label" class="text-[9px] font-bold text-white uppercase tracking-widest">0%</span>
                        </div>
                        <div class="h-1.5 w-full bg-white/[0.03] rounded-full overflow-hidden border border-white/5">
                            <div id="password-strength-bar" class="h-full w-0 bg-blue-500 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-5 bg-white hover:bg-zinc-200 text-zinc-900 text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl transition shadow-3xl shadow-white/5 active:scale-95">
                        Commit New Cipher
                    </button>

                    <% if (req.query.err === "InvalidToken") { %>
                        <div class="text-center">
                            <span class="text-rose-500 text-[9px] font-black uppercase tracking-widest">Token Synchronization Failed</span>
                        </div>
                    <% } %>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('resetPasswordForm');
            const pass = document.getElementById('password');
            const conf = document.getElementById('confirm-password');
            const bar = document.getElementById('password-strength-bar');
            const lbl = document.getElementById('password-strength-label');

            const calcStr = (p) => {
                let s = 0;
                if (p.length >= 8) s += 0.5;
                if (/\d/.test(p)) s += 0.3;
                if (/[$-/:-?{-~!"^_`\[\]]/.test(p)) s += 0.2;
                return s;
            };

            const update = () => {
                const s = calcStr(pass.value);
                bar.style.width = `${s * 100}%`;
                bar.style.backgroundColor = s < 0.5 ? '#f43f5e' : s < 0.8 ? '#fbbf24' : '#10b981';
                bar.style.boxShadow = `0 0 10px ${s < 0.5 ? '#f43f5e50' : s < 0.8 ? '#fbbf2450' : '#10b98150'}`;
                lbl.textContent = `${Math.round(s * 100)}%`;
                conf.setCustomValidity(pass.value !== conf.value ? "Ciphers do not match" : "");
            };

            pass.oninput = update;
            conf.oninput = update;
        });
    </script>
</body>
</html>
